{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)\\.mobileconfig",
            "dest": "app.py",
            "headers": {
                "Content-Type": "application/x-apple-aspen-config",
                "Content-Disposition": "attachment"
            }
        },
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ]
}